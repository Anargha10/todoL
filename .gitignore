# ========================================
# Dependencies
# ========================================
node_modules/
*/node_modules/
.pnp
.pnp.js

# ========================================
# Build outputs
# ========================================
dist/
build/
*.tsbuildinfo
.vite/

# ========================================
# Environment variables (secrets)
# Keep .env.example committed as a template
# ========================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# ========================================
# Logs
# ========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ========================================
# Testing
# ========================================
coverage/
.nyc_output/
*.lcov

# ========================================
# IDE / Editor
# ========================================
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-workspace

# ========================================
# OS files
# ========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ========================================
# Database
# ========================================
*.mongodb
*.mongodump
*.dump
dump/

# ========================================
# Deployment platforms (local configs)
# ========================================
.vercel/
.render/

# ========================================
# Misc
# ========================================
.cache/
tmp/
temp/
*.pid
*.seed
*.pid.lock

# ========================================
# TypeScript
# ========================================
*.tsbuildinfo

# ========================================
# Optional: ignore local package managers
# Uncomment if you don't want lockfiles in git
# (BUT it's better to commit lockfiles for CI/CD)
# ========================================
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
